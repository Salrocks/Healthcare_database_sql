-- ------------------------------------------------------------
-- NAME
-- ------------------------------------------------------------

-- Test: check for leading/trailing whitespace in name
-- Names were also found in random upper/lower case
SELECT name
FROM bronze.staging_table
WHERE TRIM(name) != name;

-- Fix: standardize casing (first letter of each word capitalized),
-- strip prefixes (Mr/Mrs/Ms/Dr) and suffixes (PhD/Jr/Sr/MD/II/III),
-- then split into first_name and last_name
SELECT
    INITCAP(LOWER(name)) AS name,

    TRIM(REGEXP_REPLACE(REGEXP_REPLACE(INITCAP(LOWER(name)), '^(Mr|Mrs|Ms|Dr)\.?\s*', '', 'i'),
        '\s*,?\s*(PhD|Jr|Sr|MD|II|III)\.?$', '', 'i')) AS no_prefix,

    -- First name = everything before the first space in the CLEANED name
    SUBSTRING(
        TRIM(REGEXP_REPLACE(REGEXP_REPLACE(INITCAP(LOWER(name)), '^(Mr|Mrs|Ms|Dr)\.?\s*', '', 'i'),
            '\s*,?\s*(PhD|Jr|Sr|MD|II|III)\.?$', '', 'i')),
        1,
        POSITION(' ' IN TRIM(REGEXP_REPLACE(REGEXP_REPLACE(INITCAP(LOWER(name)), '^(Mr|Mrs|Ms|Dr)\.?\s*', '', 'i'),
            '\s*,?\s*(PhD|Jr|Sr|MD|II|III)\.?$', '', 'i'))) - 1
    ) AS first_name,

    -- Last name = everything after the first space in the CLEANED name
    SUBSTRING(
        TRIM(REGEXP_REPLACE(REGEXP_REPLACE(INITCAP(LOWER(name)), '^(Mr|Mrs|Ms|Dr)\.?\s*', '', 'i'),
            '\s*,?\s*(PhD|Jr|Sr|MD|II|III)\.?$', '', 'i')),
        POSITION(' ' IN TRIM(REGEXP_REPLACE(REGEXP_REPLACE(INITCAP(LOWER(name)), '^(Mr|Mrs|Ms|Dr)\.?\s*', '', 'i'),
            '\s*,?\s*(PhD|Jr|Sr|MD|II|III)\.?$', '', 'i'))) + 1,
        LENGTH(TRIM(REGEXP_REPLACE(REGEXP_REPLACE(INITCAP(LOWER(name)), '^(Mr|Mrs|Ms|Dr)\.?\s*', '', 'i'),
            '\s*,?\s*(PhD|Jr|Sr|MD|II|III)\.?$', '', 'i')))
    ) AS last_name
FROM bronze.staging_table;


