-- ------------------------------------------------------------
-- BILLING AMOUNT
-- ------------------------------------------------------------

-- Test: identify negative values, nulls, or values with excessive decimal places
SELECT DISTINCT billing_amount
FROM bronze.staging_table
WHERE billing_amount < 0 OR billing_amount IS NULL;

-- Fix: convert negatives to their positive equivalent, nulls to 0,
-- and round everything to 2 decimal places
SELECT DISTINCT
    ROUND(billing_amount, 2) AS billing_amount,
    CASE
        WHEN billing_amount IS NULL THEN 0
        WHEN billing_amount < 0 THEN ROUND(ABS(billing_amount), 2)
        ELSE ROUND(billing_amount, 2)
    END AS fixed_billing
FROM bronze.staging_table
WHERE billing_amount < 0;  -- sanity check: confirm the CASE fix worked


