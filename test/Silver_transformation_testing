-- ------------------------------------------------------------
-- DOCTOR NAME
-- ------------------------------------------------------------

-- Test: some doctors have 'Ms./Mr./Dr.' prefixes, some have 'DDS' suffixes
-- Goal: strip prefixes/titles, keep DDS/credentials as a separate value
SELECT DISTINCT doctor_name
FROM bronze.staging_table;

-- Fix: extract clean first_name and last_name (prefix/suffix removed)
SELECT
    doctor_name,

    -- First name = everything before the first space in the cleaned name
    SPLIT_PART(
        TRIM(REGEXP_REPLACE(
            TRIM(REGEXP_REPLACE(INITCAP(LOWER(doctor_name)), '^(Mr|Mrs|Ms|Dr)\.?\s*', '', 'i')),
            '\s*,?\s*\b([A-Z]{2,5}(?:\.?,?\s*[A-Z]{2,5})*)\.?\s*$', ''
        )),
        ' ', 1
    ) AS doctor_first_name,

    -- Last name = everything after the first space in the cleaned name
    SUBSTRING(
        TRIM(REGEXP_REPLACE(
            TRIM(REGEXP_REPLACE(INITCAP(LOWER(doctor_name)), '^(Mr|Mrs|Ms|Dr)\.?\s*', '', 'i')),
            '\s*,?\s*\b([A-Z]{2,5}(?:\.?,?\s*[A-Z]{2,5})*)\.?\s*$', ''
        ))
        FROM POSITION(' ' IN TRIM(REGEXP_REPLACE(
            TRIM(REGEXP_REPLACE(INITCAP(LOWER(doctor_name)), '^(Mr|Mrs|Ms|Dr)\.?\s*', '', 'i')),
            '\s*,?\s*\b([A-Z]{2,5}(?:\.?,?\s*[A-Z]{2,5})*)\.?\s*$', ''
        ))) + 1
    ) AS doctor_last_name
FROM bronze.staging_table;


-- ------------------------------------------------------------
-- HOSPITAL
-- ------------------------------------------------------------

-- Fix: replace hyphens with spaces, remove commas, collapse extra
-- whitespace, and strip leading/trailing "and" — returns a fully
-- normalized hospital name
SELECT
    hospital,
    TRIM(
        REGEXP_REPLACE(
            REGEXP_REPLACE(
                TRIM(REGEXP_REPLACE(REPLACE(REPLACE(hospital, '-', ' '), ',', ''), '\s+', ' ', 'g')),
                '^and\s+', '', 'i'
            ),
            '\s+and$', '', 'i'
        )
    ) AS clean_hospital
FROM bronze.staging_table;


